{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:DeleteObject",
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::my-unique-static-website-id-2026",
                "arn:aws:s3:::my-unique-static-website-id-2026/*"
            ]
        }
    ]
}
